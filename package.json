{
  "name": "@fastpay/backend",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "author": "dreamgene",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test tests/*.test.ts",
