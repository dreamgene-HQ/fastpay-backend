    "jobs:reconcile": "node dist/src/reconciler/reconcile.js"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.1.1",
    "jose": "^6.1.3",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
