# Copy this file to .env and fill in real values before running the backend.
#   cp .env.example .env

# Port the HTTP server listens on.
PORT=4000

# Base URL the server considers itself reachable at (used to resolve request URLs).
APP_URL=http://localhost:4000

# Origin allowed to call the API from a browser (CORS).
FRONTEND_ORIGIN=http://localhost:3000

# PostgreSQL connection string. Matches the credentials in docker-compose.yml by default.
DATABASE_URL=postgresql://fastpay:pass@localhost:5432/fastpay

# Secret used to sign access tokens. Must be at least 32 characters. Generate with:
#   openssl rand -hex 32
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long

# How long access tokens stay valid, in seconds.
JWT_EXPIRY_SECONDS=900

# Platform fee charged on each invoice, in basis points (100 = 1.00%).
PLATFORM_FEE_BPS=100

# Additional flat platform fee per invoice, in USDC base units (7 decimals). 0 = no flat fee.
PLATFORM_FEE_FIXED_UNITS=0

# How long a newly created invoice stays payable before it expires, in minutes.
INVOICE_EXPIRY_MINUTES=60

# Stellar network passphrase. Use the testnet passphrase for local development:
#   Test SDF Network ; September 2015
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Stellar Horizon API base URL. Use the testnet Horizon for local development.
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Asset code merchants are paid in.
STELLAR_ASSET_CODE=USDC

# Stellar account that issues STELLAR_ASSET_CODE (G... public key, 56 characters).
STELLAR_ASSET_ISSUER=GCHANGEMECHANGEMECHANGEMECHANGEMECHANGEMECHANGEMECHANGEM

# Platform treasury account that receives invoice payments before reconciliation (G... public key, 56 characters).
PLATFORM_TREASURY_PUBLIC_KEY=GCHANGEMECHANGEMECHANGEMECHANGEMECHANGEMECHANGEMECHANGEM

# Optional: Horizon paging token to start reconciliation from on first run.
# Leave unset to start from "now" (only payments received after the first run are reconciled).
# RECONCILIATION_START_CURSOR=

# Comma-separated list of Stellar addresses to block from paying invoices or being screened as payers.
COMPLIANCE_BLOCKED_ADDRESSES=

# Secret used to sign outgoing webhook payloads. Must be at least 32 characters. Generate with:
#   openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=replace-with-a-random-secret-at-least-32-characters-long

# Rate limit for POST /auth/login and POST /auth/register, per client IP.
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Rate limit for GET /payments/:publicId/prepare-tx, per client IP.
PREPARE_TX_RATE_LIMIT_MAX=20
PREPARE_TX_RATE_LIMIT_WINDOW_SECONDS=60
